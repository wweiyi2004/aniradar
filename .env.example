DATABASE_URL="postgresql://aniradar:aniradar@localhost:5433/aniradar?schema=public"
REDIS_URL="redis://localhost:6379"
SCHEDULER_INTERVAL_MS=30000
CRAWLER_USER_AGENT="AniRadarBot/0.1 (+https://example.com)"
CRAWLER_TIMEOUT_MS=30000

# AI（DeepSeek，OpenAI 兼容；留空 AI_API_KEY 则使用规则 mock，项目仍可运行）
AI_API_KEY=""
AI_BASE_URL="https://api.deepseek.com"
AI_MODEL="deepseek-chat"
# 是否也翻译"非动漫情报"条目的标题/摘要（默认开；设 false 则非情报保留原文）
AI_TRANSLATE_NON_NEWS="true"

# 后台鉴权（Basic Auth）。为空则 /admin 与 /api/admin 一律拒绝访问（fail-closed）。
ADMIN_USER="admin"
ADMIN_PASSWORD=""
